# =============================================================================
# DevFlow — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# ── Supabase ─────────────────────────────────────────────────────────────────
# Project URL and anon key from your Supabase project dashboard.
# Used for database access and realtime subscriptions.
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.example

# ── Python Backend (optional) ────────────────────────────────────────────────
# Only needed if running the local Python scripts for backup/reset.
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-service-role-key
